# Supabase (recommended): use connection string from Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Or use direct Postgres vars (e.g. for local or non-Supabase)
# DB_HOST=db.xxxx.supabase.co
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=postgres
# DB_PORT=5432
# DB_SSL=true

# Session (required in production)
SESSION_SECRET=your-random-secret-key-change-this

# Optional
NODE_ENV=development
PORT=3000
